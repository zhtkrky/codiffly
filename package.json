{
  "name": "localrabbit",
  "version": "0.1.0",
  "description": "Local-first AI code review CLI for Git diffs and GitHub PRs.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "localrabbit": "./bin/localrabbit"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && tsc-alias",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4"
  }
}
